# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# AI Code Generation (Phase A+B)
ANTHROPIC_API_KEY=your-anthropic-api-key

# PromptPay (set via Admin Settings page, or env fallback)
PROMPTPAY_NUMBER=0812345678

# Slip2Go (auto slip verification)
SLIP2GO_API_URL=https://connect.slip2go.com
SLIP2GO_SECRET=your-slip2go-secret-key

# ─────── GAS Builder (Phase 1) ───────

# Site URL (used in LINE message links + email)
SITE_URL=https://kppromptcreator.tech

# LINE Messaging API
# Setup guide: docs/LINE-INTEGRATION-GUIDE.md
LINE_OA_BASIC_ID=@kpgas
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_SECRET=
ADMIN_LINE_USER_IDS=

# ─────── GAS Builder (Phase 2 — เพิ่มเมื่อทำ Done-For-You + Vercel auto-deploy) ───────

# Google OAuth (Done-For-You deploy via Apps Script API)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Google Service Account (Mode B GAS provisioning)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Vercel API (Mode B auto-deploy)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# GitHub (template repo cloning)
GITHUB_TOKEN=
GITHUB_TEMPLATE_ORG=kpgas
